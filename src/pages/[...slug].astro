---
import Layout from '../layouts/Layout.astro';
import { getAllPosts, getAllPages } from '../lib/ghost';

export async function getStaticPaths() {
  const [posts, pages] = await Promise.all([getAllPosts(), getAllPages()]);

  const postPaths = posts.map((post: any) => {
    const primarySlug = post.tags?.[0]?.slug || '';
    const category = (primarySlug === 'writing' || primarySlug === 'stories') ? 'writing' : (primarySlug === 'photos' || primarySlug === 'photography') ? 'photos' : 'misc';
    return {
      params: { slug: post.slug },
      props: { item: post, type: 'post' as const, category },
    };
  });

  const pagePaths = pages.map((page: any) => ({
    params: { slug: page.slug },
    props: { item: page, type: 'page' as const, category: 'stories' },
  }));

  return [...postPaths, ...pagePaths];
}

const { item, type, category } = Astro.props;
const isPost = type === 'post';

const relatedPosts: any[] = [];
if (isPost && item.tags?.length) {
  const allPosts = await getAllPosts();
  const primaryTag = item.tags[0].slug;
  for (const p of allPosts) {
    if (p.id === item.id) continue;
    if (p.tags?.some((t: any) => t.slug === primaryTag)) {
      relatedPosts.push(p);
    }
    if (relatedPosts.length >= 4) break;
  }
}
---
<Layout title={item.title} category={category}>
  {isPost ? (
    <article class="post-article" data-post-category={category}>
      <header class="post-header">
        <nav class="post-nav">
          <a href="/" class="post-nav-home">Hudson Paine</a>
        </nav>
      </header>
      <div class="post-content-wrapper">
        <h1 class="post-title">{item.title}</h1>
        {item.feature_image && (
          <figure class="post-feature-image">
            <img src={item.feature_image} alt={item.feature_image_alt || item.title}>
          </figure>
        )}
        <div class="post-content" set:html={item.html} />
        {relatedPosts.length > 0 && (
          <aside class="post-related">
            <div class="related-grid">
              {relatedPosts.map((p: any) => (
                <a href={`/${p.slug}/`} class="card">
                  {p.feature_image ? (
                    <div class="card-image">
                      <img src={p.feature_image} alt={p.title}>
                    </div>
                  ) : (
                    <div class="card-image card-image-placeholder"></div>
                  )}
                </a>
              ))}
            </div>
          </aside>
        )}
      </div>
    </article>
  ) : (
    <article class="page-article">
      <header class="post-header">
        <nav class="post-nav">
          <a href="/" class="post-nav-home">Hudson Paine</a>
        </nav>
      </header>
      <div class="post-content-wrapper">
        <h1 class="post-title">{item.title}</h1>
        {item.feature_image && (
          <figure class="post-feature-image">
            <img src={item.feature_image} alt={item.feature_image_alt || item.title}>
          </figure>
        )}
        <div class="post-content" set:html={item.html} />
      </div>
    </article>
  )}
</Layout>
