---
import Layout from '../layouts/Layout.astro';
import Portfolio from '../components/Portfolio.tsx';
import { loadPosts } from '../lib/posts';

const [thoughts, life] = await Promise.all([
  loadPosts('thoughts'),
  loadPosts('life'),
]);
---
<Layout title="paine.design — Hudson Paine">
  <Portfolio client:only="react" thoughts={thoughts} life={life} />
</Layout>
