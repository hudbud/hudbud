{{!< default}}

<main class="site-main">
    {{> hero}}
    {{> category-nav}}
    {{#match tag.slug "products"}}
        {{> cta-banner}}
    {{/match}}

    <section class="post-grid-section">
        <div class="post-grid">
            {{#foreach posts}}
            <a href="{{url}}" class="card" data-categories="{{#foreach tags}}{{slug}} {{/foreach}}">
                {{#if feature_image}}
                <div class="card-image">
                    <img src="{{img_url feature_image size="card"}}" alt="{{title}}">
                </div>
                {{else}}
                <div class="card-image card-image-placeholder"></div>
                {{/if}}
                <h3 class="card-title">{{title}}</h3>
            </a>
            {{/foreach}}
        </div>
        {{pagination}}
    </section>
</main>
