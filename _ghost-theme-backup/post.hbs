{{!< default}}

{{#post}}
<article class="post-article" data-post-category="{{#match primary_tag.slug "stories"}}stories{{else match primary_tag.slug "projects"}}stories{{else}}products{{/match}}">
    <header class="post-header">
        <nav class="post-nav">
            <a href="/" class="post-nav-home">Hudson Paine</a>
        </nav>
    </header>

    <div class="post-content-wrapper">
        <h1 class="post-title">{{title}}</h1>

        {{#if feature_image}}
        <figure class="post-feature-image">
            <img src="{{feature_image}}" alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}">
        </figure>
        {{/if}}

        <div class="post-content">
            {{content}}
        </div>

        <aside class="post-related">
            {{#get "posts" filter="tag:{{primary_tag.slug}}+id:-{{id}}" limit="4"}}
                {{#if posts}}
                <div class="related-grid">
                    {{#foreach posts}}
                    <a href="{{url}}" class="card">
                        {{#if feature_image}}
                        <div class="card-image">
                            <img src="{{img_url feature_image size="card"}}" alt="{{title}}">
                        </div>
                        {{else}}
                        <div class="card-image card-image-placeholder"></div>
                        {{/if}}
                    </a>
                    {{/foreach}}
                </div>
                {{/if}}
            {{/get}}
        </aside>
    </div>
</article>
{{/post}}
